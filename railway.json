{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "RAILPACK",
    "buildCommand": "chmod +x ./railway/build.sh && sh ./railway/build.sh"
  },
  "deploy": {
    "runtime": "V2",
    "numReplicas": 1,
    "startCommand": "chmod +x ./railway/start-app.sh && sh ./railway/start-app.sh",
    "healthcheckPath": "/up",
    "healthcheckTimeout": 300,
    "preDeployCommand": "chmod +x ./railway/init-app.sh && sh ./railway/init-app.sh",
    "sleepApplication": false,
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10
  }
}
